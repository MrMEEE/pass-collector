def _raise_for_http(response: requests.Response, context: str) -> None:
    if response.status_code >= 400:
        body = response.text.strip()
        raise RuntimeError(f"{context} failed ({response.status_code}): {body}")


def _load_json_map(raw: Optional[str], name: str) -> dict[str, str]:
    if not raw:
        return {}
    try:
        parsed = json.loads(raw)
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"{name} must be valid JSON") from exc
    if not isinstance(parsed, dict):
        raise RuntimeError(f"{name} must be a JSON object")
    return {str(k): str(v) for k, v in parsed.items()}


def _read_credentials(db_path: Path) -> list[dict[str, str]]:
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    try:
        rows = conn.execute(
            """
            SELECT client, cred_type, secret
            FROM credentials
            ORDER BY client, cred_type
            """
        ).fetchall()
        return [
            {
                "client": row["client"],
                "type": row["cred_type"],
                "secret": row["secret"],
            }
            for row in rows
        ]
    finally:
        conn.close()


def _ensure_vw_map_table(db_path: Path) -> None:
    conn = sqlite3.connect(db_path)
    try:
        conn.execute(
            """
            CREATE TABLE IF NOT EXISTS vaultwarden_item_map (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                client TEXT NOT NULL,
                cred_type TEXT NOT NULL,
                item_id TEXT NOT NULL,
                updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP,
                UNIQUE(client, cred_type)
            )
            """
        )
        conn.commit()
    finally:
        conn.close()


def _ensure_app_config_table(db_path: Path) -> None:
    conn = sqlite3.connect(db_path)
    try:
        conn.execute(
            """
            CREATE TABLE IF NOT EXISTS app_config (
                key TEXT PRIMARY KEY,
                value TEXT NOT NULL,
                updated_at TEXT NOT NULL DEFAULT CURRENT_TIMESTAMP
            )
            """
        )
        conn.commit()
    finally:
        conn.close()


def _set_config_value(db_path: Path, key: str, value: str) -> None:
    _ensure_app_config_table(db_path)
    conn = sqlite3.connect(db_path)
    try:
        conn.execute(
            """
            INSERT INTO app_config (key, value)
            VALUES (?, ?)
            ON CONFLICT(key)
            DO UPDATE SET
                value = excluded.value,
                updated_at = CURRENT_TIMESTAMP
            """,
            (key, value),
        )
        conn.commit()
    finally:
        conn.close()


def _get_config_value(db_path: Path, key: str) -> Optional[str]:
    _ensure_app_config_table(db_path)
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    try:
        row = conn.execute("SELECT value FROM app_config WHERE key = ?", (key,)).fetchone()
        return row["value"] if row else None
    finally:
        conn.close()


def _list_config(db_path: Path) -> dict[str, str]:
    _ensure_app_config_table(db_path)
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    try:
        rows = conn.execute("SELECT key, value FROM app_config ORDER BY key").fetchall()
        return {row["key"]: row["value"] for row in rows}
    finally:
        conn.close()


def _get_mapped_item_id(db_path: Path, client: str, cred_type: str) -> Optional[str]:
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    try:
        row = conn.execute(
            """
            SELECT item_id FROM vaultwarden_item_map
            WHERE client = ? AND cred_type = ?
            """,
            (client, cred_type),
        ).fetchone()
        return row["item_id"] if row else None
    finally:
        conn.close()


def _upsert_mapped_item_id(db_path: Path, client: str, cred_type: str, item_id: str) -> None:
    conn = sqlite3.connect(db_path)
    try:
        conn.execute(
            """
            INSERT INTO vaultwarden_item_map (client, cred_type, item_id)
            VALUES (?, ?, ?)
            ON CONFLICT(client, cred_type)
            DO UPDATE SET
                item_id = excluded.item_id,
                updated_at = CURRENT_TIMESTAMP
            """,
            (client, cred_type, item_id),
        )
        conn.commit()
    finally:
        conn.close()


def _bw_encrypt(plaintext: str, enc_key: bytes, mac_key: bytes) -> str:
    """Encrypt a UTF-8 string to Bitwarden EncString format '2.iv|ct|mac'."""
    iv = os.urandom(16)
    padder = _sym_padding.PKCS7(128).padder()
    padded = padder.update(plaintext.encode("utf-8")) + padder.finalize()
    cipher = Cipher(algorithms.AES(enc_key), modes.CBC(iv))
    encryptor = cipher.encryptor()
    ct = encryptor.update(padded) + encryptor.finalize()
    h = _crypto_hmac.HMAC(mac_key, hashes.SHA256())
    h.update(iv + ct)
    mac = h.finalize()
    return (
        f"2.{base64.b64encode(iv).decode()}"
        f"|{base64.b64encode(ct).decode()}"
        f"|{base64.b64encode(mac).decode()}"
    )


def _bw_decrypt_enc_string(enc_string: str, enc_key: bytes, mac_key: bytes) -> bytes:
    """Decrypt a Bitwarden EncString type 2 ('2.iv|ct|mac') to raw bytes."""
    if not enc_string.startswith("2."):
        raise ValueError(f"Unsupported EncString type: {enc_string[:3]!r}")
    _, rest = enc_string.split(".", 1)
    parts = rest.split("|")
    iv = base64.b64decode(parts[0])
    ct = base64.b64decode(parts[1])
    mac_bytes = base64.b64decode(parts[2])
    h = _crypto_hmac.HMAC(mac_key, hashes.SHA256())
    h.update(iv + ct)
    try:
        h.verify(mac_bytes)
    except InvalidSignature as exc:
        raise ValueError("MAC verification failed — wrong decryption key or corrupted data") from exc
    cipher = Cipher(algorithms.AES(enc_key), modes.CBC(iv))
    decryptor = cipher.decryptor()
    padded = decryptor.update(ct) + decryptor.finalize()
    unpadder = _sym_padding.PKCS7(128).unpadder()
    return unpadder.update(padded) + unpadder.finalize()


def _bw_derive_master_key(
    email: str,
    password: str,
    kdf_type: int,
    kdf_iterations: int,
    kdf_memory: Optional[int] = None,
    kdf_parallelism: Optional[int] = None,
) -> bytes:
    """Derive the 32-byte Bitwarden master key from email + password."""
    salt = email.strip().lower().encode("utf-8")
    secret = password.encode("utf-8")
    if kdf_type == 0:  # PBKDF2-SHA256
        kdf = PBKDF2HMAC(algorithm=hashes.SHA256(), length=32, salt=salt, iterations=kdf_iterations)
        return kdf.derive(secret)
    if kdf_type == 1:  # Argon2id
        try:
            from argon2.low_level import Type, hash_secret_raw  # type: ignore[import]
        except ImportError as exc:
            raise RuntimeError("argon2-cffi is required for Argon2id KDF: pip install argon2-cffi") from exc
        mem_kb = (kdf_memory or 64) * 1024  # Bitwarden stores MB; argon2 wants KB
        return hash_secret_raw(
            secret=secret,
            salt=salt,
            time_cost=kdf_iterations or 3,
            memory_cost=mem_kb,
            parallelism=kdf_parallelism or 4,
            hash_len=32,
            type=Type.ID,
        )
    raise ValueError(f"Unsupported KDF type {kdf_type}")


def _bw_stretch_master_key(master_key: bytes) -> tuple[bytes, bytes]:
    """Stretch a 32-byte master key to (enc_key, mac_key) using HKDF-Expand."""
    enc_key = HKDFExpand(algorithm=hashes.SHA256(), length=32, info=b"enc").derive(master_key)
    mac_key = HKDFExpand(algorithm=hashes.SHA256(), length=32, info=b"mac").derive(master_key)
    return enc_key, mac_key


def _bw_get_sym_keys(
    session: requests.Session,
    base_url: str,
    master_password: str,
    org_id: Optional[str] = None,
) -> tuple[bytes, bytes]:
    """Return (enc_key, mac_key) for encrypting Vaultwarden ciphers.

    If org_id is given, returns the org's shared symmetric key so that items
    placed in that org's collections are readable by all members.
    Otherwise returns the user's personal symmetric key.

    Requires the service account's master password.
    """
    resp = session.get(f"{base_url}/api/sync?excludeDomains=true", timeout=30)
    if resp.status_code >= 400:
        raise RuntimeError(f"Sync failed ({resp.status_code}): {resp.text.strip()}")
    data = resp.json()
    profile = data.get("profile") or data.get("Profile") or data

    email = profile.get("email") or profile.get("Email") or ""
    kdf_type = profile.get("kdf") if profile.get("kdf") is not None else (profile.get("Kdf") or 0)
    kdf_iter = profile.get("kdfIterations") or profile.get("KdfIterations") or 600_000
    kdf_mem = profile.get("kdfMemory") or profile.get("KdfMemory")
    kdf_par = profile.get("kdfParallelism") or profile.get("KdfParallelism")

    master_key = _bw_derive_master_key(email, master_password, int(kdf_type), int(kdf_iter), kdf_mem, kdf_par)
    stretched_enc, stretched_mac = _bw_stretch_master_key(master_key)

    # Decrypt user's 64-byte symmetric key stored in Profile.Key
    profile_key_str = profile.get("key") or profile.get("Key") or ""
    if not profile_key_str:
        raise RuntimeError("Sync profile is missing 'key' field — cannot derive encryption keys")
    user_sym_bytes = _bw_decrypt_enc_string(profile_key_str, stretched_enc, stretched_mac)
    user_enc_key = user_sym_bytes[:32]
    user_mac_key = user_sym_bytes[32:64]

    if not org_id:
        return user_enc_key, user_mac_key

    # For org ciphers: decrypt org symmetric key via user's RSA private key.
    priv_key_str = profile.get("privateKey") or profile.get("PrivateKey") or ""
    if not priv_key_str:
        raise RuntimeError("Sync profile is missing 'privateKey' — cannot decrypt org encryption key")
    priv_key_der = _bw_decrypt_enc_string(priv_key_str, user_enc_key, user_mac_key)
    rsa_key = load_der_private_key(priv_key_der, password=None)

    orgs_list = profile.get("organizations") or profile.get("Organizations") or []
    org_entry = next(
        (o for o in orgs_list if (o.get("id") or o.get("Id") or "").lower() == org_id.lower()),
        None,
    )
    if org_entry is None:
        raise RuntimeError(
            f"Organization {org_id} not found in sync profile. "
            "Make sure the service account is a member of that organization."
        )
    org_key_str = org_entry.get("key") or org_entry.get("Key") or ""
    if not org_key_str:
        raise RuntimeError(f"Organization {org_id} has no 'key' in the sync profile")

    # Type 4: RSA-OAEP encrypted (standard Bitwarden format)
    if org_key_str.startswith("4."):
        rsa_ct = base64.b64decode(org_key_str[2:])
        org_sym_bytes = rsa_key.decrypt(
            rsa_ct,
            _asym_padding.OAEP(
                mgf=_asym_padding.MGF1(algorithm=hashes.SHA1()),
                algorithm=hashes.SHA1(),
                label=None,
            ),
        )
        return org_sym_bytes[:32], org_sym_bytes[32:64]

    # Type 2: symmetric (older/non-standard format)
    if org_key_str.startswith("2."):
        org_sym_bytes = _bw_decrypt_enc_string(org_key_str, user_enc_key, user_mac_key)
        return org_sym_bytes[:32], org_sym_bytes[32:64]

    raise ValueError(f"Unsupported org key EncString type: {org_key_str[:3]!r}")


def _build_payload(
    client: str,
    secret: str,
    cred_type: str,
    org_id: Optional[str],
    client_map: dict[str, str],
    type_map: dict[str, str],
    name_template: str,
    username_template: str,
    notes_template: str,
    collection_id: Optional[str] = None,
    sym_keys: Optional[tuple[bytes, bytes]] = None,
) -> dict[str, Any]:
    mapped_client = client_map.get(client, client)
    mapped_type = type_map.get(cred_type, cred_type)
    values = {
        "client": mapped_client,
        "type": mapped_type,
        "raw_client": client,
        "raw_type": cred_type,
    }

    def _enc(s: str) -> str:
        if sym_keys:
            return _bw_encrypt(s, sym_keys[0], sym_keys[1])
        return s

    payload: dict[str, Any] = {
        "type": 1,
        "name": _enc(name_template.format(**values)),
        "notes": _enc(notes_template.format(**values)),
        "favorite": False,
        "login": {
            "username": _enc(username_template.format(**values)),
            "password": _enc(secret),
            "totp": None,
            "uris": [],
        },
        "collectionIds": [collection_id] if collection_id else [],
        "folderId": None,
        "secureNote": None,
        "card": None,
        "identity": None,
        "reprompt": 0,
    }
    if org_id:
        payload["organizationId"] = org_id
    return payload


def _extract_cipher_id(payload: Any) -> str:
    if isinstance(payload, dict):
        cipher_id = payload.get("id") or payload.get("Id")
        if cipher_id:
            return str(cipher_id)

        nested = payload.get("data") or payload.get("Data")
        if isinstance(nested, dict):
            cipher_id = nested.get("id") or nested.get("Id")
            if cipher_id:
                return str(cipher_id)

    raise RuntimeError("Vaultwarden create response did not include cipher id")


def _fetch_bearer_token(base_url: str, client_id: str, client_secret: str, verify_ssl: bool = True) -> str:
    url = f"{base_url}/identity/connect/token"
    try:
        resp = requests.post(
            url,
            data={
                "grant_type": "client_credentials",
                "client_id": client_id,
                "client_secret": client_secret,
                "scope": "api",
                "DeviceIdentifier": str(uuid.uuid4()),
                "DeviceType": "21",
                "DeviceName": "pass-collector",
            },
            verify=verify_ssl,
            timeout=15,
        )
    except requests.RequestException as exc:
        raise RuntimeError(f"Token request to {url} failed: {exc}") from exc
    if resp.status_code >= 400:
        raise RuntimeError(f"Token request failed ({resp.status_code}): {resp.text.strip()}")
    data = resp.json()
    token = data.get("access_token")
    if not token:
        raise RuntimeError("Token response did not include access_token")
    return str(token)


def _create_session(vw_api_url: str, vw_access_token: str, verify_ssl: bool = True) -> requests.Session:
    s = requests.Session()
    s.headers.update(
        {
            "Authorization": f"Bearer {vw_access_token}",
            "Content-Type": "application/json",
        }
    )
    s.verify = verify_ssl
    if not verify_ssl:
        urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    return s


def _resolve_setting(args: argparse.Namespace, db_path: Path, arg_name: str, config_key: str, required: bool = False) -> Optional[str]:
    value = getattr(args, arg_name)
    if value:
        return value
    value = _get_config_value(db_path, config_key)
    if required and not value:
        raise RuntimeError(
            f"Missing setting {config_key}. Provide --{arg_name.replace('_', '-')} or set it via 'pass-collector-config config'."
        )
    return value


def _prompt_value(prompt: str, default: Optional[str] = None, required: bool = False) -> str:
    while True:
        suffix = f" [{default}]" if default else ""
        value = input(f"{prompt}{suffix}: ").strip()
        if not value and default is not None:
            value = default
        if value or not required:
            return value
        print("Value is required.")


def _prompt_yes_no(prompt: str, default: bool = False) -> bool:
    default_hint = "Y/n" if default else "y/N"
    while True:
        raw = input(f"{prompt} [{default_hint}]: ").strip().lower()
        if not raw:
            return default
        if raw in {"y", "yes"}:
            return True
        if raw in {"n", "no"}:
            return False
        print("Please answer yes or no.")


def _prompt_choice(prompt: str, choices: list[str], default: str) -> str:
    allowed = "/".join(choices)
    while True:
        raw = input(f"{prompt} [{default}] ({allowed}): ").strip()
        if not raw:
            return default
        if raw in choices:
            return raw
        print(f"Please choose one of: {allowed}")


def _extract_orgs_from_payload(payload: Any) -> list[dict[str, str]]:
    found: list[dict[str, str]] = []

    def walk(value: Any) -> None:
        if isinstance(value, dict):
            org_id = value.get("id") or value.get("uuid") or value.get("org_uuid")
            org_name = value.get("name") or value.get("org_name")
            if org_id and org_name:
                found.append({"id": str(org_id), "name": str(org_name)})
            for nested in value.values():
                walk(nested)
            return
        if isinstance(value, list):
            for nested in value:
                walk(nested)

    walk(payload)

    deduped: list[dict[str, str]] = []
    seen: set[str] = set()
    for org in found:
        key = org["id"]
        if key not in seen:
            seen.add(key)
            deduped.append(org)
    return deduped


_UUID_RE = re.compile(
    r'[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}',
    re.IGNORECASE,
)


def _extract_orgs_from_html(html: str) -> list[dict[str, str]]:
    """Extract orgs from Vaultwarden admin organizations/overview HTML page.

    Vaultwarden embeds page data as JSON inside a <script> tag, e.g.:
        pageData = [...];
    If that is not found, fall back to scraping UUIDs from delete-form actions.
    """
    orgs: list[dict[str, str]] = []
    seen: set[str] = set()

    # Primary: extract embedded JSON from <script> tags (Vaultwarden template pattern)
    script_re = re.compile(r'<script[^>]*>(.*?)</script>', re.DOTALL | re.IGNORECASE)
    json_assign_re = re.compile(
        r'(?:pageData|orgData|organizations)\s*[=:]\s*(\[.*?\])\s*[;,]?\s*(?:\n|$|var |let |const )',
        re.DOTALL | re.IGNORECASE,
    )
    for script_match in script_re.finditer(html):
        script_body = script_match.group(1)
        for assign_match in json_assign_re.finditer(script_body):
            try:
                payload = json.loads(assign_match.group(1))
                candidates = _extract_orgs_from_payload(payload)
                for org in candidates:
                    if org["id"] not in seen:
                        seen.add(org["id"])
                        orgs.append(org)
            except Exception:
                continue

    if orgs:
        return orgs

    # Secondary: look for delete-form action URLs which contain org UUIDs,
    # then try to pair with the preceding table-cell text (org name).
    row_re = re.compile(r'<tr[^>]*>(.*?)</tr>', re.DOTALL | re.IGNORECASE)
    uuid_re = re.compile(_UUID_RE.pattern, re.IGNORECASE)
    td_inner_re = re.compile(r'<td[^>]*>(.*?)</td>', re.DOTALL | re.IGNORECASE)

    def _clean_html_text(fragment: str) -> str:
        # Remove tags and normalize whitespace so anchor-wrapped org names are captured.
        no_tags = re.sub(r"<[^>]+>", " ", fragment)
        return re.sub(r"\s+", " ", html.unescape(no_tags)).strip()

    for row_match in row_re.finditer(html):
        row_html = row_match.group(1)
        uuids_in_row = uuid_re.findall(row_html)
        if not uuids_in_row:
            continue
        td_cells = td_inner_re.findall(row_html)
        texts = [_clean_html_text(cell) for cell in td_cells]
        # First non-UUID text cell is likely the org name
        name = next(
            (
                t
                for t in texts
                if t
                and not uuid_re.fullmatch(t)
                and t.lower() not in ("delete", "remove")
            ),
            "",
        )
        uid = uuids_in_row[0].lower()
        if uid not in seen:
            seen.add(uid)
            orgs.append({"id": uid, "name": name or uid})

    return orgs


def list_organizations(session: requests.Session, base_url: str) -> list[dict[str, str]]:
    # The correct Vaultwarden admin endpoint is /admin/organizations/overview (HTML only).
    # There is no JSON org-listing endpoint in the admin API.
    # We also try /admin/users which returns JSON and may contain org membership data.

    # Try scraping the organizations overview page (HTML with embedded JSON)
    for endpoint in [
        f"{base_url}/admin/organizations/overview",
        f"{base_url}/admin/organizations",   # older versions
    ]:
        try:
            resp = session.get(endpoint, timeout=15)
            if resp.status_code >= 400:
                continue
            # If the response is JSON, parse directly
            ct = resp.headers.get("Content-Type", "")
            if "json" in ct:
                orgs = _extract_orgs_from_payload(resp.json())
            else:
                orgs = _extract_orgs_from_html(resp.text)
            if orgs:
                return orgs
        except Exception:
            continue

    # Last resort: query /admin/users (returns JSON) and extract unique org UUIDs
    # from memberships embedded in user records.
    try:
        resp = session.get(f"{base_url}/admin/users", timeout=15)
        if resp.status_code < 400:
            orgs = _extract_orgs_from_payload(resp.json())
            if orgs:
                return orgs
    except Exception:
        pass

    raise RuntimeError("Could not list organizations from Vaultwarden admin/API endpoints")

def _prompt_select_organization(orgs: list[dict[str, str]]) -> str:
    print("Available organizations:")
    options: list[str] = []
    for idx, org in enumerate(orgs, start=1):
        print(f"  {idx}. {org['name']} ({org['id']})")
        options.append(str(idx))

    selected = _prompt_choice("Choose organization number", options, default="1")
    return orgs[int(selected) - 1]["id"]


def list_collections(session: requests.Session, base_url: str, org_id: str) -> list[dict[str, str]]:
    resp = session.get(f"{base_url}/api/organizations/{org_id}/collections", timeout=15)
    if resp.status_code >= 400:
        raise RuntimeError(f"Could not list collections ({resp.status_code}): {resp.text.strip()}")
    data = resp.json()
    items = data.get("data", data) if isinstance(data, dict) else data
    if not isinstance(items, list):
        raise RuntimeError("Unexpected response format from collections endpoint")
    result = []
    for item in items:
        coll_id = item.get("id") or item.get("Id")
        coll_name = item.get("name") or item.get("Name") or coll_id
        if coll_id:
            result.append({"id": str(coll_id), "name": str(coll_name)})
    return result


def _prompt_select_collection(collections: list[dict[str, str]]) -> str:
    # Collection names are client-side encrypted; only the UUID is usable here.
    print("Available collections (names are encrypted and cannot be displayed):")
    options: list[str] = []
    for idx, coll in enumerate(collections, start=1):
        print(f"  {idx}. {coll['id']}")
        options.append(str(idx))
    selected = _prompt_choice("Choose collection number", options, default="1")
    return collections[int(selected) - 1]["id"]


def cmd_migrate(args: argparse.Namespace) -> int:
    db_path = Path(args.db_path)
    _ensure_vw_map_table(db_path)

    dry_run: bool = getattr(args, "dry_run", False)

    # Full interactive mode: URL not available from args or DB config, and not a dry-run.
    interactive_mode = (
        not dry_run
        and not getattr(args, "vw_api_url", None)
        and not _get_config_value(db_path, "VW_API_URL")
    )

    # --- Base URL ---
    vw_api_url = _resolve_setting(args, db_path, "vw_api_url", "VW_API_URL")
    if not vw_api_url and not dry_run:
        vw_api_url = _prompt_value("Vaultwarden API base URL", required=True)
    vw_api_url = (vw_api_url or "").rstrip("/")

    # --- SSL ---
    verify_ssl_cfg = _get_config_value(db_path, "VW_VERIFY_SSL")
    verify_ssl = not args.no_verify_ssl and (verify_ssl_cfg or "").lower() not in ("false", "0", "no")

    # --- Field mappings (prompt in full interactive mode) ---
    client_map_json = _resolve_setting(args, db_path, "client_map_json", "VW_CLIENT_MAP_JSON")
    type_map_json = _resolve_setting(args, db_path, "type_map_json", "VW_TYPE_MAP_JSON")
    name_template = _resolve_setting(args, db_path, "name_template", "VW_NAME_TEMPLATE") or "pass-collector:{client}:{type}"
    username_template = _resolve_setting(args, db_path, "username_template", "VW_USERNAME_TEMPLATE") or "{client}"
    notes_template = _resolve_setting(args, db_path, "notes_template", "VW_NOTES_TEMPLATE") or "client={client}; type={type}"

    if interactive_mode:
        print("\n-- Credential field mapping (press Enter to keep defaults) --")
        inp = _prompt_value('Type map JSON (e.g. {"ssh":"Linux root"})', default=type_map_json or "")
        type_map_json = inp or type_map_json
        inp = _prompt_value('Client map JSON (e.g. {"acme":"ACME-PROD"})', default=client_map_json or "")
        client_map_json = inp or client_map_json
        name_template = _prompt_value("Name template", default=name_template) or name_template
        username_template = _prompt_value("Username template", default=username_template) or username_template
        notes_template = _prompt_value("Notes template", default=notes_template) or notes_template

    client_map = _load_json_map(client_map_json, "VW_CLIENT_MAP_JSON")
    type_map = _load_json_map(type_map_json, "VW_TYPE_MAP_JSON")

    # --- Read credentials from SQLite ---
    entries = _read_credentials(db_path)

    # --- Dry-run shortcut (no auth or network needed) ---
    if dry_run:
        vw_organization_id = _resolve_setting(args, db_path, "vw_organization_id", "VW_ORGANIZATION_ID")
        vw_collection_id = _resolve_setting(args, db_path, "vw_collection_id", "VW_COLLECTION_ID")
        preview = []
        for entry in entries:
            client = entry["client"]
            cred_type = entry["type"]
            payload = _build_payload(
                client=client,
                secret="***",
                cred_type=cred_type,
                org_id=vw_organization_id,
                client_map=client_map,
                type_map=type_map,
                name_template=name_template,
                username_template=username_template,
                notes_template=notes_template,
                collection_id=vw_collection_id,
            )
            existing_id = _get_mapped_item_id(db_path, client, cred_type)
            preview.append({
                "client": client,
                "type": cred_type,
                "action": "update" if existing_id else "create",
                "existing_cipher_id": existing_id,
                "vaultwarden_payload": payload,
            })
        print(json.dumps({"dry_run": True, "total": len(preview), "entries": preview}, indent=2))
        return 0

    # --- Auth ---
    vw_access_token = _resolve_setting(args, db_path, "vw_access_token", "VW_ACCESS_TOKEN")
    vw_client_id = _resolve_setting(args, db_path, "vw_client_id", "VW_CLIENT_ID")
    vw_client_secret = _resolve_setting(args, db_path, "vw_client_secret", "VW_CLIENT_SECRET")

    if not vw_access_token and not (vw_client_id and vw_client_secret):
        print("\n-- Authentication --")
        auth_method = _prompt_choice(
            "Authentication method",
            choices=["token", "client"],
            default="client",
        )
        if auth_method == "token":
            vw_access_token = getpass.getpass("API bearer token: ")
        else:
            vw_client_id = _prompt_value("client_id", required=True)
            vw_client_secret = getpass.getpass("client_secret: ")

    if not vw_access_token:
        if vw_client_id and vw_client_secret:
            vw_access_token = _fetch_bearer_token(vw_api_url, vw_client_id, vw_client_secret, verify_ssl)
        else:
            raise RuntimeError(
                "VW_ACCESS_TOKEN or both VW_CLIENT_ID and VW_CLIENT_SECRET are required. "
                "Provide --vw-access-token, or both --vw-client-id and --vw-client-secret."
            )

    session = _create_session(vw_api_url, vw_access_token, verify_ssl=verify_ssl)

    # --- Organization ---
    vw_organization_id = _resolve_setting(args, db_path, "vw_organization_id", "VW_ORGANIZATION_ID")
    if not vw_organization_id:
        print("\n-- Organization --")
        try:
            orgs = list_organizations(session, vw_api_url)
            if orgs:
                vw_organization_id = _prompt_select_organization(orgs)
            else:
                vw_organization_id = _prompt_value("Organization UUID (optional)", required=False) or None
        except RuntimeError as exc:
            print(f"Could not auto-discover organizations: {exc}")
            vw_organization_id = _prompt_value("Organization UUID (optional)", required=False) or None

    # --- Collection ---
    vw_collection_id = _resolve_setting(args, db_path, "vw_collection_id", "VW_COLLECTION_ID")
    if not vw_collection_id and vw_organization_id:
        print("\n-- Collection --")
        print("Without a collection, items are encrypted with the service account key and")
        print("other users will see [error: cannot decrypt].")
        try:
            collections = list_collections(session, vw_api_url, vw_organization_id)
            if collections:
                if _prompt_yes_no("Assign items to a collection?", default=True):
                    vw_collection_id = _prompt_select_collection(collections)
            else:
                vw_collection_id = _prompt_value("Collection UUID (optional)", required=False) or None
        except RuntimeError as exc:
            print(f"Could not list collections: {exc}")
            vw_collection_id = _prompt_value("Collection UUID (optional)", required=False) or None

    # --- Encryption keys (master password required) ---
    # Vaultwarden is end-to-end encrypted: all cipher fields must be encrypted
    # with the org's (or user's) symmetric key before being sent to the API.
    #
    # First check if a pre-derived sym key is already stored (avoids re-prompting).
    sym_keys: Optional[tuple[bytes, bytes]] = None
    stored_sym_key = _get_config_value(db_path, "VW_SYM_KEY")
    if stored_sym_key:
        try:
            raw = base64.b64decode(stored_sym_key)
            sym_keys = (raw[:32], raw[32:64])
            print("Using stored encryption key (VW_SYM_KEY).")
        except Exception:
            stored_sym_key = None  # fall through to password prompt

    if sym_keys is None:
        print("\n-- Encryption --")
        print("Vaultwarden is end-to-end encrypted. The service account's master password")
        print("is required to derive the encryption key. It is never stored.")
        master_password = getpass.getpass("Service account master password: ")
        try:
            sym_keys = _bw_get_sym_keys(
                session, vw_api_url, master_password, vw_organization_id
            )
            print("Encryption keys derived successfully.")
        except ValueError as exc:
            print(f"ERROR: {exc}")
            print("This usually means the master password is wrong.")
            raise SystemExit(1)
        except RuntimeError as exc:
            print(f"ERROR: {exc}")
            raise SystemExit(1)

        # Offer to save the derived key (not the master password) for the live backend.
        print("\nThe derived symmetric key (not the master password) can be saved to")
        print("data.db so the live backend (app.py) can encrypt new incoming credentials.")
        print("The master password itself is never stored.")
        if _prompt_yes_no("Save encryption key to data.db for live backend?", default=False):
            encoded = base64.b64encode(sym_keys[0] + sym_keys[1]).decode()
            _set_config_value(db_path, "VW_SYM_KEY", encoded)
            print("VW_SYM_KEY saved.")

    # --- Save settings to DB ---
    if interactive_mode and _prompt_yes_no("\nSave these settings to data.db for future runs?", default=True):
        to_save = [
            ("VW_API_URL", vw_api_url),
            ("VW_ORGANIZATION_ID", vw_organization_id),
            ("VW_COLLECTION_ID", vw_collection_id),
            ("VW_TYPE_MAP_JSON", type_map_json),
            ("VW_CLIENT_MAP_JSON", client_map_json),
        ]
        if name_template != "pass-collector:{client}:{type}":
            to_save.append(("VW_NAME_TEMPLATE", name_template))
        if username_template != "{client}":
            to_save.append(("VW_USERNAME_TEMPLATE", username_template))
        if notes_template != "client={client}; type={type}":
            to_save.append(("VW_NOTES_TEMPLATE", notes_template))
        for key, val in to_save:
            if val:
                _set_config_value(db_path, key, val)
        print("Settings saved (credentials not saved for security).")

    # --- Optional dry-run preview before live migration ---
    if interactive_mode and _prompt_yes_no(f"\nPreview {len(entries)} item(s) before migrating?", default=True):
        preview = []
        for entry in entries:
            client = entry["client"]
            cred_type = entry["type"]
            payload = _build_payload(
                client=client,
                secret="***",
                cred_type=cred_type,
                org_id=vw_organization_id,
                client_map=client_map,
                type_map=type_map,
                name_template=name_template,
                username_template=username_template,
                notes_template=notes_template,
                collection_id=vw_collection_id,
                # sym_keys intentionally omitted: preview shows plaintext templates
            )
            existing_id = _get_mapped_item_id(db_path, client, cred_type)
            preview.append({
                "client": client,
                "type": cred_type,
                "action": "update" if existing_id else "create",
                "existing_cipher_id": existing_id,
                "vaultwarden_payload": payload,
            })
        print(json.dumps({"dry_run": True, "total": len(preview), "entries": preview}, indent=2))
        if not _prompt_yes_no(f"\nProceed with migrating {len(entries)} item(s)?", default=False):
            print("Migration cancelled.")
            return 0

    # --- Run migration ---
    migrated = 0
    failures: list[dict[str, str]] = []

    for entry in entries:
        client = entry["client"]
        cred_type = entry["type"]
        secret = entry["secret"]

        try:
            old_id = _get_mapped_item_id(db_path, client, cred_type)
            if old_id:
                delete_resp = session.delete(f"{vw_api_url}/api/ciphers/{quote_plus(old_id)}", timeout=20)
                if delete_resp.status_code not in (200, 204, 404, 410):
                    _raise_for_http(delete_resp, "Delete existing cipher")

            payload = _build_payload(
                client=client,
                secret=secret,
                cred_type=cred_type,
                org_id=vw_organization_id,
                client_map=client_map,
                type_map=type_map,
                name_template=name_template,
                username_template=username_template,
                notes_template=notes_template,
                collection_id=vw_collection_id,
                sym_keys=sym_keys,
            )
            if vw_collection_id:
                create_resp = session.post(f"{vw_api_url}/api/ciphers/create", json={"cipher": payload, "collectionIds": [vw_collection_id]}, timeout=20)
            else:
                create_resp = session.post(f"{vw_api_url}/api/ciphers", json=payload, timeout=20)
            _raise_for_http(create_resp, "Create cipher")
            new_id = _extract_cipher_id(create_resp.json())
            _upsert_mapped_item_id(db_path, client, cred_type, new_id)
            migrated += 1
        except Exception as exc:
            failures.append(
                {
                    "client": client,
                    "type": cred_type,
                    "error": str(exc),
                }
            )

    print(
        json.dumps(
            {
                "ok": len(failures) == 0,
                "total": len(entries),
                "migrated": migrated,
                "failed": len(failures),
                "failures": failures,
            },
            indent=2,
        )
    )

    return 0 if not failures else 2


def admin_login(session: requests.Session, base_url: str, admin_token: str) -> None:
    resp = session.post(
        f"{base_url}/admin",
        data={"token": admin_token},
        timeout=15,
        allow_redirects=False,
    )

    if resp.status_code not in (200, 302, 303):
        _raise_for_http(resp, "Admin login")

    if "VW_ADMIN" not in session.cookies.get_dict():
        raise RuntimeError("Admin login did not return VW_ADMIN session cookie")


def invite_user(session: requests.Session, base_url: str, email: str) -> dict[str, Any]:
    resp = session.post(
        f"{base_url}/admin/invite",
        headers={"Content-Type": "application/json"},
        data=json.dumps({"email": email}),
        timeout=15,
    )

    if resp.status_code == 409:
        return {"already_exists": True}

    _raise_for_http(resp, "Invite user")
    return {"already_exists": False, "payload": resp.json()}


def get_user_by_mail(session: requests.Session, base_url: str, email: str) -> dict[str, Any]:
    quoted = quote(email, safe="")
    resp = session.get(f"{base_url}/admin/users/by-mail/{quoted}", timeout=15)
    _raise_for_http(resp, "Get user by mail")

    data = resp.json()
    if not isinstance(data, dict) or not data.get("id"):
        raise RuntimeError("Unexpected response from /admin/users/by-mail/<mail>")
    return data


def set_membership_type(
    session: requests.Session,
    base_url: str,
    user_uuid: str,
    org_uuid: str,
    user_type: str,
) -> None:
    payload = {
        "user_type": user_type,
        "user_uuid": user_uuid,
        "org_uuid": org_uuid,
    }

    resp = session.post(
        f"{base_url}/admin/users/org_type",
        headers={"Content-Type": "application/json"},
        data=json.dumps(payload),
        timeout=15,
    )
    _raise_for_http(resp, "Set organization role")


def cmd_service_user(args: argparse.Namespace) -> int:
    db_path = Path(args.db_path)
    interactive_mode = all(
        [
            not args.base_url,
            not args.email,
            not args.org_uuid,
            "--org-role" not in sys.argv,
        ]
    )

    base_url_default = _resolve_setting(args, db_path, "base_url", "VW_API_URL")

    base_url = (args.base_url or "").strip()
    if not base_url:
        base_url = _prompt_value("Vaultwarden base URL", default=base_url_default, required=True)
    base_url = base_url.rstrip("/")

    email = (args.email or "").strip()
    if not email:
        email = _prompt_value("Service user email", required=True)

    admin_token = args.admin_token or getpass.getpass("Vaultwarden ADMIN_TOKEN: ")

    verify_ssl_cfg = _get_config_value(db_path, "VW_VERIFY_SSL")
    verify_ssl = not args.no_verify_ssl and (verify_ssl_cfg or "").lower() not in ("false", "0", "no")

    session = requests.Session()
    session.verify = verify_ssl
    if not verify_ssl:
        urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

    admin_login(session, base_url, admin_token)

    org_uuid = (args.org_uuid or "").strip()
    if not org_uuid:
        if interactive_mode and _prompt_yes_no("Set organization membership role now?", default=False):
            try:
                orgs = list_organizations(session, base_url)
                org_uuid = _prompt_select_organization(orgs)
            except RuntimeError as exc:
                print(f"Could not auto-discover organizations: {exc}")
                print("Hint: find org UUIDs in the Vaultwarden admin panel under Organizations.")
                org_uuid = _prompt_value("Organization UUID (leave blank to skip)", required=False)
        elif not interactive_mode:
            org_uuid = _prompt_value("Organization UUID (optional)", required=False)
    org_uuid = org_uuid or None

    org_role = args.org_role
    if org_uuid and "--org-role" not in sys.argv:
        role_prompt = "Organization role (0=Owner, 1=Admin, 2=User, 3=Manager)"
        org_role = _prompt_choice(role_prompt, ["0", "1", "2", "3"], default=org_role)

    invite_result = invite_user(session, base_url, email)

    if invite_result.get("already_exists"):
        print(f"User already exists: {email}")
    else:
        print(f"Invited/created user: {email}")

    if org_uuid:
        user_data = get_user_by_mail(session, base_url, email)
        user_id = user_data["id"]
        try:
            set_membership_type(
                session=session,
                base_url=base_url,
                user_uuid=user_id,
                org_uuid=org_uuid,
                user_type=org_role,
            )
            print(
                "Updated org role successfully "
                f"(org={org_uuid}, user={user_id}, role={org_role})."
            )
        except RuntimeError as exc:
            print("Could not set org role automatically.")
            print(f"Reason: {exc}")
            print("This usually means the user is not yet a member of that organization.")
            print("Invite the user to the org first, then rerun this command with --org-uuid.")

    print("Done.")
    return 0


def cmd_config(args: argparse.Namespace) -> int:
    db_path = Path(args.db_path)

    if args.show:
        current = _list_config(db_path)
        print(json.dumps(current, indent=2))
        return 0

    changed = 0

    for pair in args.set or []:
        if "=" not in pair:
            raise RuntimeError(f"Invalid --set value '{pair}', expected KEY=VALUE")
        key, value = pair.split("=", 1)
        key = key.strip()
        if key not in CONFIG_KEYS:
            raise RuntimeError(f"Unsupported config key '{key}'. Allowed: {', '.join(CONFIG_KEYS)}")
        _set_config_value(db_path, key, value)
        changed += 1

    arg_to_key = {
        "backend": "BACKEND",
        "vw_api_url": "VW_API_URL",
        "vw_access_token": "VW_ACCESS_TOKEN",
        "vw_client_id": "VW_CLIENT_ID",
        "vw_client_secret": "VW_CLIENT_SECRET",
        "vw_organization_id": "VW_ORGANIZATION_ID",
        "vw_collection_id": "VW_COLLECTION_ID",
        "vw_verify_ssl": "VW_VERIFY_SSL",
        "client_map_json": "VW_CLIENT_MAP_JSON",
        "type_map_json": "VW_TYPE_MAP_JSON",
        "name_template": "VW_NAME_TEMPLATE",
        "username_template": "VW_USERNAME_TEMPLATE",
        "notes_template": "VW_NOTES_TEMPLATE",
    }

    for arg_name, key in arg_to_key.items():
        value = getattr(args, arg_name)
        if value is not None:
            _set_config_value(db_path, key, value)
            changed += 1

    if changed == 0:
        # Friendly UX: with no config flags, show subcommand help instead of traceback.
        parser = getattr(args, "_subparser", None)
        if parser is not None:
            parser.print_help()
            return 0
        raise RuntimeError("No configuration values provided. Use --show, --set KEY=VALUE, or explicit flags.")

    print(f"Saved {changed} configuration value(s) to {db_path}")
    return 0


def cmd_fetch_key(args: argparse.Namespace) -> int:
    """Derive the Vaultwarden symmetric encryption key from the master password
    and save it as VW_SYM_KEY in data.db.

    The master password is entered once via a secure prompt and is never stored.
    VW_SYM_KEY is the 64-byte derived key (enc+mac) encoded as base64. It
    cannot be used to log in to Vaultwarden — only to encrypt/decrypt ciphers.
    """
    db_path = Path(args.db_path)

    vw_api_url = _resolve_setting(args, db_path, "vw_api_url", "VW_API_URL")
    if not vw_api_url:
        vw_api_url = _prompt_value("Vaultwarden API base URL", required=True)
    vw_api_url = vw_api_url.rstrip("/")

    verify_ssl_cfg = _get_config_value(db_path, "VW_VERIFY_SSL")
    verify_ssl = not args.no_verify_ssl and (verify_ssl_cfg or "").lower() not in ("false", "0", "no")

    vw_access_token = _resolve_setting(args, db_path, "vw_access_token", "VW_ACCESS_TOKEN")
    if not vw_access_token:
        vw_client_id = _resolve_setting(args, db_path, "vw_client_id", "VW_CLIENT_ID")
        vw_client_secret = _resolve_setting(args, db_path, "vw_client_secret", "VW_CLIENT_SECRET")
        if vw_client_id and vw_client_secret:
            vw_access_token = _fetch_bearer_token(vw_api_url, vw_client_id, vw_client_secret, verify_ssl)
        else:
            vw_access_token = getpass.getpass("API bearer token (or set VW_ACCESS_TOKEN / VW_CLIENT_ID+SECRET): ")

    session = _create_session(vw_api_url, vw_access_token, verify_ssl=verify_ssl)

    vw_organization_id = _resolve_setting(args, db_path, "vw_organization_id", "VW_ORGANIZATION_ID")

    master_password = getpass.getpass("Service account master password: ")

    try:
        sym_keys = _bw_get_sym_keys(session, vw_api_url, master_password, vw_organization_id)
    except ValueError as exc:
        print(f"ERROR: {exc}")
        print("This usually means the master password is wrong.")
        return 1
    except RuntimeError as exc:
        print(f"ERROR: {exc}")
        return 1

    encoded = base64.b64encode(sym_keys[0] + sym_keys[1]).decode()
    _set_config_value(db_path, "VW_SYM_KEY", encoded)
    print(f"VW_SYM_KEY saved to {db_path}.")
    print("The live backend (app.py) will now encrypt new credentials with the org key.")
    print("Restart the pass-collector service to pick up the new key.")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="pass-collector-config",
        description="General configuration and migration utility for pass-collector",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    service_user = sub.add_parser("service-user", help="Invite/create Vaultwarden service user")
    service_user.add_argument("--db-path", default=str(DEFAULT_DB_PATH), help="Path to data.db")
    service_user.add_argument("--base-url", default=None, help="Vaultwarden base URL (falls back to DB config VW_API_URL)")
    service_user.add_argument("--email", default=None, help="Service user email")
    service_user.add_argument("--admin-token", default=None, help="Vaultwarden ADMIN_TOKEN (optional prompt)")
    service_user.add_argument("--org-uuid", default=None, help="Optional organization UUID")
    service_user.add_argument("--org-role", default="2", choices=["0", "1", "2", "3"], help="0=Owner,1=Admin,2=User,3=Manager")
    service_user.add_argument("--no-verify-ssl", action="store_true", default=False, help="Disable SSL certificate verification (accept self-signed certs)")
    service_user.set_defaults(func=cmd_service_user)

    fetch_key = sub.add_parser("fetch-key", help="Derive and store the Vaultwarden encryption key from the master password (entered once, never stored)")
    fetch_key.add_argument("--db-path", default=str(DEFAULT_DB_PATH), help="Path to data.db")
    fetch_key.add_argument("--vw-api-url", default=None, help="Vaultwarden API base URL (falls back to DB config VW_API_URL)")
    fetch_key.add_argument("--vw-access-token", default=None, help="Vaultwarden API bearer token")
    fetch_key.add_argument("--vw-client-id", default=None, help="Vaultwarden API client_id")
    fetch_key.add_argument("--vw-client-secret", default=None, help="Vaultwarden API client_secret")
    fetch_key.add_argument("--vw-organization-id", default=None, help="Organization UUID (falls back to DB config VW_ORGANIZATION_ID)")
    fetch_key.add_argument("--no-verify-ssl", action="store_true", default=False, help="Disable SSL certificate verification")
    fetch_key.set_defaults(func=cmd_fetch_key)

    migrate = sub.add_parser("migrate", help="Migrate SQLite credentials to Vaultwarden")
    migrate.add_argument("--db-path", default=str(DEFAULT_DB_PATH), help="Path to data.db")
    migrate.add_argument("--vw-api-url", default=None, help="Vaultwarden API base URL (defaults to DB config VW_API_URL)")
    migrate.add_argument("--vw-access-token", default=None, help="Vaultwarden API bearer token (defaults to DB config VW_ACCESS_TOKEN)")
    migrate.add_argument("--vw-client-id", default=None, help="Vaultwarden API client_id (used to fetch bearer token if --vw-access-token is not set)")
    migrate.add_argument("--vw-client-secret", default=None, help="Vaultwarden API client_secret (used to fetch bearer token if --vw-access-token is not set)")
    migrate.add_argument("--vw-organization-id", default=None, help="Optional organization UUID")
    migrate.add_argument("--vw-collection-id", default=None, help="Org collection UUID — items are assigned here and encrypted with the org key (required for shared visibility)")
    migrate.add_argument("--client-map-json", default=None, help="JSON map for client remapping")
    migrate.add_argument("--type-map-json", default=None, help="JSON map for type remapping")
    migrate.add_argument("--name-template", default=None, help="Vaultwarden item name template")
    migrate.add_argument("--username-template", default=None, help="Vaultwarden username template")
    migrate.add_argument("--notes-template", default=None, help="Vaultwarden notes template")
    migrate.add_argument("--no-verify-ssl", action="store_true", default=False, help="Disable SSL certificate verification (accept self-signed certs)")
    migrate.add_argument("--dry-run", action="store_true", default=False, help="Show what would be migrated without making any API calls")
    migrate.set_defaults(func=cmd_migrate)

    config = sub.add_parser("config", help="Read/write pass-collector config stored in SQLite")
    config.add_argument("--db-path", default=str(DEFAULT_DB_PATH), help="Path to data.db")
    config.add_argument("--show", action="store_true", help="Show current config")
    config.add_argument("--set", action="append", default=[], help="Set a raw key/value pair as KEY=VALUE")
    config.add_argument("--backend", choices=["sqlite", "vaultwarden"], default=None)
    config.add_argument("--vw-api-url", default=None)
    config.add_argument("--vw-access-token", default=None)
    config.add_argument("--vw-client-id", default=None)
    config.add_argument("--vw-client-secret", default=None)
    config.add_argument("--vw-organization-id", default=None)
    config.add_argument("--vw-collection-id", default=None)
    config.add_argument("--client-map-json", default=None)
    config.add_argument("--type-map-json", default=None)
    config.add_argument("--name-template", default=None)
    config.add_argument("--username-template", default=None)
    config.add_argument("--notes-template", default=None)
    config.add_argument("--vw-verify-ssl", choices=["true", "false"], default=None, help="Set to 'false' to accept self-signed SSL certificates")
    config.set_defaults(_subparser=config)
    config.set_defaults(func=cmd_config)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
